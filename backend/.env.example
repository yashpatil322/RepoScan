# Google Gemini API key (free tier available at https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Gemini model to use (default: gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash

# Optional: Embedding model (default: all-MiniLM-L6-v2)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Optional: ChromaDB storage path (default: ./data/chroma_db)
CHROMA_DB_PATH=./data/chroma_db

# Optional: Repo registry path (default: ./data/repos_registry.json)
REPOS_REGISTRY_PATH=./data/repos_registry.json

# Optional: Cloned repos temp directory (default: system temp)
# CLONE_DIR=./data/tmp_repos
